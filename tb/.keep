`timescale 1ns / 1ps

module tb_sign_mag_adder;

    localparam SIZE = 8;

    logic [SIZE-1:0] a;
    logic [SIZE-1:0] b;
    logic [SIZE-1:0] s;
    logic            overflow;

    // ????????? ???????????? ??????
    sign_mag_adder #(
        .SIZE(SIZE)
    ) dut (
        .a(a),
        .b(b),
        .s(s),
        .overflow(overflow)
    );

    // ??????? ??? ???????????? ????? ? ?????? ???? ??? ??????
    function logic [SIZE-1:0] make_sm(input logic sign, input logic [SIZE-2:0] mag);
        return {sign, mag};
    endfunction

    // ?????? ??? ???????? ??????????
    task check_result(
        input logic [SIZE-1:0] expected_s,
        input logic            expected_ovf,
        input string           test_name
    );
        #1; // ????????? ???????? ??? ???????????? ?????????????? ??????
        if (s !== expected_s || overflow !== expected_ovf) begin
            $error("FAIL [%s]: a=%b, b=%b -> s=%b (exp %b), ovf=%b (exp %b)", 
                   test_name, a, b, s, expected_s, overflow, expected_ovf);
        end else begin
            $display("PASS [%s]", test_name);
        end
    endtask

    initial begin
        $display("?????? ???????????? ????????? ? ?????? ????...");

        // 1. ?????????? ????? (?????????????)
        a = make_sm(0, 7'd10); b = make_sm(0, 7'd5);
        check_result(make_sm(0, 7'd15), 0, "+10 + (+5) = +15");

        // 2. ?????????? ????? (?????????????)
        a = make_sm(1, 7'd10); b = make_sm(1, 7'd5);
        check_result(make_sm(1, 7'd15), 0, "-10 + (-5) = -15");

        // 3. ?????? ????? (a_mag > b_mag)
        a = make_sm(1, 7'd20); b = make_sm(0, 7'd5);
        check_result(make_sm(1, 7'd15), 0, "-20 + (+5) = -15");

        // 4. ?????? ????? (b_mag > a_mag)
        a = make_sm(0, 7'd5); b = make_sm(1, 7'd20);
        check_result(make_sm(1, 7'd15), 0, "+5 + (-20) = -15");

        // 5. ?????? ????? (????????? ???? ? ????????????)
        a = make_sm(1, 7'd12); b = make_sm(0, 7'd12);
        check_result(make_sm(0, 7'd0), 0, "-12 + (+12) = +0");

        // 6. ???????? +0 ? -0 (???????????? ????)
        a = make_sm(0, 7'd0); b = make_sm(1, 7'd0);
        check_result(make_sm(0, 7'd0), 0, "+0 + (-0) = +0");

        // 7. ???????? -0 ? -0 (???????????? ????)
        a = make_sm(1, 7'd0); b = make_sm(1, 7'd0);
        check_result(make_sm(0, 7'd0), 0, "-0 + (-0) = +0");

        // 8. ???????????? (????????????? ?????)
        // ???????????? ?????? ??? 8 ??? = 127 (7'b1111111)
        a = make_sm(0, 7'd100); b = make_sm(0, 7'd30);
        // 100 + 30 = 130 > 127. 130 ? ????????: 10000010 (??????? 7 ??? = 0000010, ?.?. 2)
        check_result(make_sm(0, 7'd2), 1, "????????????: +100 + (+30)");

        // 9. ???????????? (????????????? ?????)
        a = make_sm(1, 7'd120); b = make_sm(1, 7'd10);
        // -120 + (-10) = -130
        check_result(make_sm(1, 7'd2), 1, "????????????: -120 + (-10)");

        $display("???????????? ?????????.");
        $finish;
    end

endmodule
